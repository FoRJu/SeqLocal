// conf/base.config — process resource + execution directives by label.
// Included from the root nextflow.config.

process {

    // Defaults for every process.
    cpus   = 2
    memory = 4.GB
    errorStrategy = 'terminate'

    // GPU basecalling/demux: host Dorado binary, NOT containerized (ADR-0005).
    // Serialize the single RTX 4090 and never wrap this in a container/conda.
    withLabel: gpu {
        maxForks  = 1
        cpus      = 8
        memory    = 16.GB
        container = null
        conda     = null
    }

    // samtools/seqkit steps from the pinned ont-tools conda env (default path).
    // Under -profile docker/singularity, fill `container` at M6 (ADR-0006).
    withLabel: samtools {
        cpus   = 4
        memory = 8.GB
        conda  = "${projectDir}/environment.yml"
        // container = 'TODO-M6: pinned samtools image'
    }

    // CPU-heavy assembly steps (Flye/raven/miniasm + autocycler) from ont-tools.
    // M4 (ADR-0010). Tune to the host; the RTX 4090 box has ample CPU/RAM.
    withLabel: assembly {
        cpus   = 16
        memory = 32.GB
        conda  = "${projectDir}/environment.yml"
        // container = 'TODO-M6: pinned assembly image'
    }
}
