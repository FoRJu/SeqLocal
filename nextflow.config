// nextflow.config — root entry (Nextflow auto-loads this from the launch dir).
// ONT sequencing-service pipeline. M1: basecall + demux.
// Process resource directives live in conf/base.config; this file holds params,
// the manifest, and execution profiles.

manifest {
    name            = 'ont-pipeline'
    author          = 'Oncology-CRO sequencing service'
    description      = 'Oxford Nanopore plasmid / amplicon analysis pipeline'
    mainScript      = 'workflows/main.nf'
    nextflowVersion = '>=26.04.0'
    version         = '0.1.0-M1'
}

params {
    // --- Inputs (required) ---
    pod5_dir             = null            // directory of POD5 files
    barcode_kit          = null            // e.g. SQK-NBD114-24 (validate vs `dorado demux --help`)

    // --- Outputs ---
    outdir               = 'results'

    // --- Basecalling ---
    basecall_model       = 'hac@v6.0'      // pinned shorthand; SUP via 'sup@v6.0' for high-value jobs
    cuda_device          = 'cuda:0'        // pin the single RTX 4090 for determinism
    no_trim              = false           // keep default ONT adapter/barcode trimming

    // --- Tool locations (host binary; ADR-0005) ---
    dorado_bin           = "${projectDir}/tools/dorado/bin/dorado"
    dorado_models_dir    = "${projectDir}/tools/dorado-models"

    // --- QC ---
    min_reads_per_barcode = 0              // warn (non-fatal) below this count
}

// Default: assume Dorado 2.0.0 host binary is on the box. Override at runtime.
profiles {

    // Local execution, host binaries. Non-Dorado steps run from whatever is on PATH.
    standard {
        process.executor = 'local'
    }

    // Default for M1 runs: non-Dorado steps use the pinned ont-tools conda env.
    conda {
        process.executor = 'local'
        conda.enabled    = true
        // Per-label conda assignment is in conf/base.config (withLabel:samtools).
    }

    // Containers — directives scaffolded; per-process images filled at M6 (ADR-0006).
    docker {
        process.executor = 'local'
        docker.enabled   = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    singularity {
        process.executor          = 'local'
        singularity.enabled       = true
        singularity.autoMounts    = true
    }

    // Tiny structural smoke test: `-profile test,conda -stub-run`.
    test {
        params.pod5_dir    = "${projectDir}/assets/test/pod5"
        params.barcode_kit = 'SQK-NBD114-24'
    }
}

includeConfig 'conf/base.config'

// Run provenance.
timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline.html" }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report.html" }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/trace.txt" }
